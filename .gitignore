# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ---- Dependencies ----
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ---- Next.js / build output ----
/.next/
/out/
/build
/dist

# ---- Caches ----
.turbo
.swc/
.eslintcache
*.tsbuildinfo
.cache/

# ---- Testing / coverage ----
/coverage
/playwright-report
/test-results

# ---- TypeScript ----
next-env.d.ts

# ---- Environment variables (never commit secrets) ----
.env
.env.*
!.env.example

# ---- Vercel ----
.vercel

# ---- Supabase (se mantienen migrations/ y config.toml; se ignoran cachés locales) ----
supabase/.temp/
supabase/.branches/
supabase/.env

# ---- Logs ----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ---- OS ----
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db

# ---- Editors / IDE ----
.idea/
*.swp
*.swo
*.suo
*.ntvs*
*.njsproj
*.sln

# ---- Misc / secrets ----
*.pem
