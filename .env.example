NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase server
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
CRON_SECRET=generate-a-long-random-secret

# URL pública de la app (sin barra final). Imprescindible para que los SMS
# generen enlaces absolutos al recibo y al cartel desde el cron (sin request).
# En Vercel basta con VERCEL_PROJECT_PRODUCTION_URL, pero conviene fijarla.
APP_BASE_URL=https://www.pandatenis.com

# SMS — Twilio (https://www.twilio.com/console)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=
# Remitente: número E.164 (+34...) o Sender ID alfanumérico (ej. "Panda Tenis").
TWILIO_FROM=
# Alternativa al remitente: SID de un Messaging Service (opcional).
TWILIO_MESSAGING_SERVICE_SID=

# WhatsApp Business Cloud API (Meta)
# Genera el system user token con permiso whatsapp_business_messaging
META_WHATSAPP_ACCESS_TOKEN=
# ID numérico del número emisor en Meta Business Manager
META_PHONE_NUMBER_ID=
# WhatsApp Business Account ID (WABA)
META_WABA_ID=
# App secret de Meta (para validar la firma X-Hub-Signature-256 del webhook)
META_APP_SECRET=
# ID numérico de la app de Meta (Meta for Developers → tu app → Configuración →
# Básica). Necesario para subir el archivo de cabecera de plantillas con foto,
# vídeo o documento (resumable upload / header_handle).
META_APP_ID=
# Verify token que pegarás en Meta al configurar el webhook (cadena aleatoria)
META_WEBHOOK_VERIFY_TOKEN=
# Versión de Graph API (opcional, por defecto v20.0)
META_GRAPH_API_VERSION=v20.0
